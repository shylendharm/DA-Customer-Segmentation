# %% [markdown]
# # 🎯 Customer Segmentation Analytics
# ## Project Presentation
# 
# **Objective:** Categorize customers based on behaviour and demographics using clustering techniques.
# 
# **Expected Outcome:** Customer groups for targeted marketing strategies.

# %%
# Import required libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.metrics import silhouette_score
import warnings
warnings.filterwarnings('ignore')

# Set plot style
plt.style.use('seaborn-v0_8-whitegrid')
sns.set_palette("husl")
print("✓ Libraries loaded successfully")

# %% [markdown]
# ## 1. Dataset Overview

# %%
# Load data
df = pd.read_csv('Mall_Customers.csv')

print(f"📊 Dataset: {df.shape[0]} customers × {df.shape[1]} features")
print(f"\nColumns: {list(df.columns)}")
print(f"\n📋 First 10 Records:")
df.head(10)

# %% [markdown]
# ## 2. Data Summary Statistics

# %%
df.describe()

# %% [markdown]
# ## 3. Exploratory Data Analysis

# %%
fig, axes = plt.subplots(2, 2, figsize=(14, 10))

# Gender distribution
axes[0, 0].pie(df['Genre'].value_counts(), labels=['Female', 'Male'], 
               autopct='%1.1f%%', colors=['#e74c3c', '#3498db'], startangle=90)
axes[0, 0].set_title('Gender Distribution', fontweight='bold')

# Age distribution
axes[0, 1].hist(df['Age'], bins=15, color='#2ecc71', edgecolor='black', alpha=0.7)
axes[0, 1].set_xlabel('Age')
axes[0, 1].set_ylabel('Frequency')
axes[0, 1].set_title('Age Distribution', fontweight='bold')

# Income distribution
axes[1, 0].hist(df['Annual Income (k$)'], bins=15, color='#9b59b6', edgecolor='black', alpha=0.7)
axes[1, 0].set_xlabel('Annual Income (k$)')
axes[1, 0].set_ylabel('Frequency')
axes[1, 0].set_title('Annual Income Distribution', fontweight='bold')

# Spending Score distribution
axes[1, 1].hist(df['Spending Score (1-100)'], bins=15, color='#e67e22', edgecolor='black', alpha=0.7)
axes[1, 1].set_xlabel('Spending Score')
axes[1, 1].set_ylabel('Frequency')
axes[1, 1].set_title('Spending Score Distribution', fontweight='bold')

plt.tight_layout()
plt.show()

# %% [markdown]
# ## 4. Correlation Analysis

# %%
plt.figure(figsize=(8, 6))
numeric_cols = ['Age', 'Annual Income (k$)', 'Spending Score (1-100)']
corr_matrix = df[numeric_cols].corr()
sns.heatmap(corr_matrix, annot=True, cmap='coolwarm', center=0, fmt='.2f', square=True)
plt.title('Feature Correlation Heatmap', fontweight='bold', fontsize=14)
plt.tight_layout()
plt.show()

# %% [markdown]
# ## 5. Determining Optimal Clusters (Elbow Method)

# %%
# Prepare data
X = df[numeric_cols].values
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# Calculate metrics for different k values
k_range = range(2, 11)
inertias = []
silhouette_scores_list = []

for k in k_range:
    kmeans_temp = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels_temp = kmeans_temp.fit_predict(X_scaled)
    inertias.append(kmeans_temp.inertia_)
    silhouette_scores_list.append(silhouette_score(X_scaled, labels_temp))

# Plot
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

axes[0].plot(k_range, inertias, 'bo-', linewidth=2, markersize=8)
axes[0].set_xlabel('Number of Clusters (K)', fontsize=12)
axes[0].set_ylabel('Inertia', fontsize=12)
axes[0].set_title('Elbow Method', fontweight='bold', fontsize=14)
axes[0].grid(True, alpha=0.3)

axes[1].plot(k_range, silhouette_scores_list, 'go-', linewidth=2, markersize=8)
axes[1].axhline(y=max(silhouette_scores_list), color='r', linestyle='--', 
                label=f'Max Score: {max(silhouette_scores_list):.3f}')
axes[1].set_xlabel('Number of Clusters (K)', fontsize=12)
axes[1].set_ylabel('Silhouette Score', fontsize=12)
axes[1].set_title('Silhouette Analysis', fontweight='bold', fontsize=14)
axes[1].legend()
axes[1].grid(True, alpha=0.3)

plt.tight_layout()
plt.show()

print(f"✅ Optimal K selected: 5 clusters (balanced interpretability & metrics)")

# %% [markdown]
# ## 6. K-Means Clustering Results

# %%
# Apply K-Means with 5 clusters
n_clusters = 5
kmeans = KMeans(n_clusters=n_clusters, random_state=42, n_init=10)
df['Cluster'] = kmeans.fit_predict(X_scaled)

print(f"✓ Clustering completed with {n_clusters} segments")
print(f"\n📊 Cluster Distribution:")
for i in range(n_clusters):
    count = (df['Cluster'] == i).sum()
    pct = count / len(df) * 100
    print(f"   Cluster {i}: {count} customers ({pct:.1f}%)")

# %% [markdown]
# ## 7. Customer Segments Visualization (Income vs Spending)

# %%
plt.figure(figsize=(12, 8))

cluster_colors = ['#e74c3c', '#3498db', '#2ecc71', '#f39c12', '#9b59b6']
segment_names = ['Budget-Conscious\nConservative', 'Young Active\nSpenders', 
                 'High Earners\nActive', 'High Earners\nConservative', 
                 'Mature Balanced\nSpenders']

for cluster in range(n_clusters):
    mask = df['Cluster'] == cluster
    plt.scatter(df[mask]['Annual Income (k$)'], df[mask]['Spending Score (1-100)'],
                c=cluster_colors[cluster], label=f'C{cluster}: {segment_names[cluster]}',
                s=150, alpha=0.7, edgecolors='black', linewidth=0.5)

# Plot cluster centers
plt.scatter(kmeans.cluster_centers_[:, 1], kmeans.cluster_centers_[:, 2],
            c='red', s=500, marker='X', label='Cluster Centers',
            edgecolors='black', linewidth=3)

plt.xlabel('Annual Income (k$)', fontsize=12, fontweight='bold')
plt.ylabel('Spending Score (1-100)', fontsize=12, fontweight='bold')
plt.title('🎯 Customer Segments: Income vs Spending Behavior', fontsize=16, fontweight='bold')
plt.legend(title='Segments', loc='best', fontsize=9)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

# %% [markdown]
# ## 8. PCA Visualization (2D Projection)

# %%
pca = PCA(n_components=2)
X_pca = pca.fit_transform(X_scaled)

plt.figure(figsize=(10, 8))

for cluster in range(n_clusters):
    mask = df['Cluster'] == cluster
    plt.scatter(X_pca[mask, 0], X_pca[mask, 1],
                c=cluster_colors[cluster], label=f'Cluster {cluster}',
                s=150, alpha=0.7, edgecolors='black', linewidth=0.5)

centers_pca = pca.transform(kmeans.cluster_centers_)
plt.scatter(centers_pca[:, 0], centers_pca[:, 1],
            c='red', s=400, marker='X', label='Centers',
            edgecolors='black', linewidth=2)

plt.xlabel(f'PC1 ({pca.explained_variance_ratio_[0]:.1%} variance)', fontsize=12)
plt.ylabel(f'PC2 ({pca.explained_variance_ratio_[1]:.1%} variance)', fontsize=12)
plt.title('📊 Customer Segments (PCA Visualization)', fontsize=14, fontweight='bold')
plt.legend(loc='best')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

# %% [markdown]
# ## 9. Segment Profiles

# %%
cluster_profiles = df.groupby('Cluster').agg({
    'Age': 'mean',
    'Annual Income (k$)': 'mean',
    'Spending Score (1-100)': 'mean',
    'CustomerID': 'count'
}).round(2)

cluster_profiles.columns = ['Avg_Age', 'Avg_Income_k', 'Avg_Spending_Score', 'Customer_Count']
cluster_profiles['Segment_Percentage'] = (cluster_profiles['Customer_Count'] / len(df) * 100).round(1)

# Add segment names
cluster_profiles['Segment_Name'] = [
    'Budget-Conscious, Conservative',
    'Young Active Spenders',
    'High Earners, Active Spenders',
    'High Earners, Conservative',
    'Mature Balanced Spenders'
]

print("📋 CUSTOMER SEGMENT PROFILES")
print("=" * 80)
print(cluster_profiles[['Segment_Name', 'Customer_Count', 'Segment_Percentage', 
                        'Avg_Age', 'Avg_Income_k', 'Avg_Spending_Score']].to_string())

# %% [markdown]
# ## 10. Segment Characteristics Comparison

# %%
fig, axes = plt.subplots(1, 3, figsize=(15, 5))

cluster_means = df.groupby('Cluster')[['Age', 'Annual Income (k$)', 'Spending Score (1-100)']].mean()

# Age comparison
axes[0].bar(range(n_clusters), cluster_means['Age'], color='#3498db', edgecolor='black')
axes[0].set_xlabel('Cluster', fontsize=11)
axes[0].set_ylabel('Average Age', fontsize=11)
axes[0].set_title('Average Age by Segment', fontweight='bold')
axes[0].set_xticks(range(n_clusters))
axes[0].grid(True, alpha=0.3, axis='y')

# Income comparison
axes[1].bar(range(n_clusters), cluster_means['Annual Income (k$)'], color='#2ecc71', edgecolor='black')
axes[1].set_xlabel('Cluster', fontsize=11)
axes[1].set_ylabel('Annual Income (k$)', fontsize=11)
axes[1].set_title('Average Income by Segment', fontweight='bold')
axes[1].set_xticks(range(n_clusters))
axes[1].grid(True, alpha=0.3, axis='y')

# Spending comparison
axes[2].bar(range(n_clusters), cluster_means['Spending Score (1-100)'], color='#e74c3c', edgecolor='black')
axes[2].set_xlabel('Cluster', fontsize=11)
axes[2].set_ylabel('Spending Score', fontsize=11)
axes[2].set_title('Average Spending Score by Segment', fontweight='bold')
axes[2].set_xticks(range(n_clusters))
axes[2].grid(True, alpha=0.3, axis='y')

plt.tight_layout()
plt.show()

